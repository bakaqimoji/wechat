<view class="container">
  <view class="profile-header">
    <view class="avatar-section">
      <image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
      <view class="edit-avatar" bindtap="onEditAvatar">📷</view>
    </view>
    <view class="user-basic-info">
      <view class="user-name">{{userInfo.name}}</view>
      <view class="user-level">🏆 健身达人 Lv.5</view>
    </view>
  </view>

  <view class="stats-section">
    <view class="stat-item">
      <view class="stat-number">{{userInfo.stats.matches}}</view>
      <view class="stat-label">匹配次数</view>
    </view>
    <view class="stat-item">
      <view class="stat-number">{{userInfo.stats.hours}}</view>
      <view class="stat-label">训练时长</view>
    </view>
    <view class="stat-item">
      <view class="stat-number">{{userInfo.stats.coaches}}</view>
      <view class="stat-label">合作教练</view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="onEditProfile">
      <text class="menu-icon">👤</text>
      <text class="menu-text">编辑个人资料</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="onFitnessGoals">
      <text class="menu-icon">🎯</text>
      <text class="menu-text">健身目标设置</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="onTrainingHistory">
      <text class="menu-icon">📊</text>
      <text class="menu-text">训练记录</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="onSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="logout-section">
    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>
</view>
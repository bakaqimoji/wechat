.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.coach-header {
  background-color: #fff;
  padding: 40rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative;
}

.avatar-section {
  position: relative;
  margin-right: 32rpx;
}

.coach-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
}

.share-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 60rpx;
  height: 60rpx;
  background-color: #4CAF50;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.edit-avatar-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 50rpx;
  height: 50rpx;
  background-color: #2196F3;
  border-radius: 25rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.coach-basic-info {
  flex: 1;
}

.coach-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.coach-specialty {
  font-size: 28rpx;
  color: #4CAF50;
  margin-bottom: 12rpx;
}

.coach-rating {
  display: flex;
  align-items: center;
}

.rating-stars {
  font-size: 24rpx;
  margin-right: 12rpx;
}

.rating-score {
  font-size: 26rpx;
  color: #666;
}

.info-section {
  background-color: #fff;
  margin: 0 20rpx 20rpx 20rpx;
  padding: 32rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  margin-bottom: 16rpx;
  align-items: center;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  min-width: 120rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.skills {
  display: flex;
  flex-wrap: wrap;
}

.skill-tag {
  background-color: #e8f5e8;
  color: #4CAF50;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.introduction {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 24rpx 20rpx;
  display: flex;
  gap: 16rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
}

.contact-btn, .match-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.contact-btn {
  background-color: #2196F3;
  color: white;
}

.match-btn {
  background-color: #4CAF50;
  color: white;
}
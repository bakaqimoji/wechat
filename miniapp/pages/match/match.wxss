.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.match-header {
  background: linear-gradient(135deg, #4CAF50, #45a049);
  padding: 60rpx 40rpx;
  text-align: center;
  color: white;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  display: block;
}

.header-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.match-preferences {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.preference-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.preference-item:last-child {
  border-bottom: none;
}

.preference-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.picker-display {
  font-size: 28rpx;
  color: #666;
  padding: 8rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  min-width: 120rpx;
  text-align: center;
}

.match-button {
  padding: 40rpx 20rpx;
}

.match-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: white;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.recent-matches {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.match-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.match-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.match-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
}

.match-info {
  flex: 1;
}

.match-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.match-status {
  font-size: 24rpx;
}

.match-status.success {
  color: #4CAF50;
}

.match-status.pending {
  color: #ff9800;
}

.match-time {
  font-size: 24rpx;
  color: #999;
}